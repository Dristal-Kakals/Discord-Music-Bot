DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_test_server_id_here
MUSIC_TEXT_CHANNEL_ID=music_text_channel_id_here

# Optional Spotify API credentials. Spotify links are used as metadata/search, not direct audio streams.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Web panel
WEB_HTTPS_PORT=3443
WEB_SSL_KEY=/opt/dsbot/certs/key.pem
WEB_SSL_CERT=/opt/dsbot/certs/cert.pem

# Optional. If WEB_VOICE_CHANNEL_ID is empty, web play uses the first voice channel with a non-bot member.
WEB_VOICE_CHANNEL_ID=voice_channel_id_for_web_play_here
WEB_TEXT_CHANNEL_ID=text_channel_id_for_now_playing_messages_here
